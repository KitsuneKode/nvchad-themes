    "url": "https://github.com/KitsuneKode/nvchad-themes/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KitsuneKode/nvchad-themes.git"
  },
  "qna": "marketplace",
  "preview": false,
  "type": "module",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes"
  ],

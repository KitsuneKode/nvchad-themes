  "scripts": {
    "build": "bun run scripts/build-theme.ts",
    "import:base46": "bun run scripts/import-base46.ts",
    "package": "bun run scripts/package-dist.ts",
    "package:vsix": "bun run scripts/package-theme.ts",
    "install:zed": "bun run scripts/install-zed-theme.ts",
    "install:zed-dev": "bun run scripts/install-zed-dev.ts",
    "install:codex": "bun run scripts/install-codex-theme.ts",
    "install:gemini": "bun run scripts/install-gemini-theme.ts",
    "install:opencode": "bun run scripts/install-opencode-theme.ts",
    "test": "bun test",
    "goldens": "bun run scripts/generate-golden-extracts.ts",
    "goldens:check": "bun run scripts/generate-golden-extracts.ts --check",
    "previews": "bun run scripts/run-previews.ts",
    "previews:raster": "bun run scripts/render-preview-raster.ts",
    "previews:check": "bun run scripts/previews-check.ts",
    "verify": "bun run scripts/verify-extensions.ts",
    "publish:vscode": "bun run package && bunx @vscode/vsce publish",
    "publish:vscode:ovsx": "bun run package && bunx ovsx publish dist/*.vsix",
    "vscode:prepublish": "bun run build"
  },

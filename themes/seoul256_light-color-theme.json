    "class": "#875F87",
    "interface": "#875F87",
    "enum": "#AF8760",
    "enumMember": "#678e8e",
    "struct": "#875F87",
    "function": "#5F87AE",
    "method": "#5F87AE",
    "decorator": "#5F87AE",
    "macro": "#6a6a6a",
    "variable": "#4E4E4E",
    "parameter": "#6a6a6a",
    "property": "#6a6a6a",
    "label": "#AF8760",
    "event": "#6a6a6a",

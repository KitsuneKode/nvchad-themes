    "class": "#F2AFFD",
    "interface": "#F2AFFD",
    "enum": "#13C299",
    "enumMember": "#24DFC4",
    "struct": "#F2AFFD",
    "function": "#24ACD4",
    "method": "#24ACD4",
    "decorator": "#24ACD4",
    "macro": "#E3C401",
    "variable": "#E6E6E6",
    "parameter": "#E3C401",
    "property": "#E3C401",
    "label": "#13C299",
    "event": "#E3C401",
    "modifier": "#E3C401",
    "variable.defaultLibrary": "#24DFC4",
    "variable.readonly.defaultLibrary": "#24DFC4",
    "type.defaultLibrary": "#13C299"
  }

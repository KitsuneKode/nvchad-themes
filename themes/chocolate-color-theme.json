    "struct": "#c65f5f",
    "function": "#7d92a2",
    "method": "#7d92a2",
    "decorator": "#7d92a2",
    "macro": "#c65f5f",
    "variable": "#c8bAA4",
    "parameter": "#c65f5f",
    "property": "#c65f5f",
    "label": "#d9b27c",
    "event": "#c65f5f",

    "class": "#9c86bf",
    "interface": "#9c86bf",
    "enum": "#dca561",
    "enumMember": "#ffa066",
    "struct": "#9c86bf",
    "function": "#7e9cd8",
    "method": "#7e9cd8",
    "decorator": "#7e9cd8",
    "macro": "#d8616b",
    "variable": "#c8c3a6",

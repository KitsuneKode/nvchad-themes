  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#545076"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "meta.embedded.assembly"
      ],
      "settings": {
        "foreground": "#b77bf9"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#FF8B39"
      }
    },
    {
      "name": "Numbers And Booleans",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#72F1B8"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#72F1B8"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#61E2FF"
      }
    },
    {
      "name": "Builtin Variables And Parameters",
      "scope": [
        "variable.language",
        "variable.parameter",
        "variable.other.readwrite.alias",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#61E2FF"
      }
    },
    {
      "name": "Properties And Keys",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#61E2FF"
      }
    },
    {
      "name": "Functions And Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "meta.method-call",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#FFCC00"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression",
        "storage",
        "storage.modifier",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#FC199A"
      }
    },
    {
      "name": "Types",
      "scope": [
        "storage.type",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution"
      ],
      "settings": {
        "foreground": "#FC199A"
      }
    },
    {
      "name": "Constructors And Specials",
      "scope": [
        "meta.function-call.constructor",
        "support.class",
        "support.type.builtin",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#FF8B39"
      }
    },
    {
      "name": "Tag Names",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "meta.tag.structure.any.html"
      ],
      "settings": {
        "foreground": "#FC199A"
      }
    },
    {
      "name": "Tag Delimiters And Punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.separator.key-value",
        "punctuation.separator.delimiter",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#40dbfc"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.definition.generic"
      ],
      "settings": {
        "foreground": "#61E2FF"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#61E2FF"
      }
    },
    {
      "name": "Markup Headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#FFCC00"
      }
    },
    {
      "name": "Markup Emphasis",
      "scope": [
        "markup.bold",
        "markup.italic"
      ],
      "settings": {
        "foreground": "#72F1B8"
      }
    },
    {
      "name": "Markup Links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#FF8B39",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": [
        "markup.inserted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#72F1B8"
      }
    },
    {
      "name": "Diff Removed",
      "scope": [
        "markup.deleted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#FE4450"
      }
    },
    {
      "name": "Diff Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#605c88"
      }
    }
  ],
  "semanticTokenColors": {
    "comment": "#545076",
    "string": "#b77bf9",
    "regexp": "#40dbfc",
    "number": "#72F1B8",
    "boolean": "#72F1B8",
    "keyword": "#FC199A",
    "operator": "#61E2FF",
    "namespace": "#61E2FF",
    "type": "#FC199A",
    "typeParameter": "#FC199A",
    "class": "#FC199A",
    "interface": "#FC199A",
    "enum": "#FC199A",
    "enumMember": "#72F1B8",
    "struct": "#FC199A",
    "function": "#FFCC00",
    "method": "#FFCC00",
    "decorator": "#FFCC00",
    "macro": "#61E2FF",
    "variable": "#61E2FF",
    "parameter": "#61E2FF",
    "property": "#61E2FF",
    "label": "#FC199A",
    "event": "#61E2FF",
    "modifier": "#61E2FF",
    "variable.defaultLibrary": "#72F1B8",
    "variable.readonly.defaultLibrary": "#72F1B8",
    "type.defaultLibrary": "#FC199A"
  }
}

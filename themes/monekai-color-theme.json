    "class": "#f92672",
    "interface": "#f92672",
    "enum": "#f4bf75",
    "enumMember": "#ae81ff",
    "struct": "#f92672",
    "function": "#66d9ef",
    "method": "#66d9ef",
    "decorator": "#66d9ef",
    "macro": "#fd971f",
    "variable": "#f8f8f2",
    "parameter": "#fd971f",
    "property": "#fd971f",
    "label": "#f4bf75",

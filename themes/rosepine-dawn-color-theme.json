    "class": "#ea9d34",
    "interface": "#ea9d34",
    "enum": "#d7827e",
    "enumMember": "#ea9d34",
    "struct": "#ea9d34",
    "function": "#907aa9",
    "method": "#907aa9",
    "decorator": "#907aa9",
    "macro": "#b4637a",
    "variable": "#575279",
    "parameter": "#b4637a",
    "property": "#b4637a",
    "label": "#d7827e",
    "event": "#b4637a",

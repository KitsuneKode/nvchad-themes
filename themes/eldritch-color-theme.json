    "struct": "#A48CF2",
    "function": "#7081D0",
    "method": "#7081D0",
    "decorator": "#7081D0",
    "macro": "#F16C75",
    "variable": "#ABB4DA",
    "parameter": "#F16C75",
    "property": "#F16C75",
    "label": "#F7C67F",

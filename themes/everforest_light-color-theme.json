  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#A39D8C"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "meta.embedded.assembly"
      ],
      "settings": {
        "foreground": "#d59600"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#ef615e"
      }
    },
    {
      "name": "Numbers And Booleans",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#b67996"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#b67996"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#495157"
      }
    },
    {
      "name": "Builtin Variables And Parameters",
      "scope": [
        "variable.language",
        "variable.parameter",
        "variable.other.readwrite.alias",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#5f9b93"
      }
    },
    {
      "name": "Properties And Keys",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#5f9b93"
      }
    },
    {
      "name": "Functions And Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "meta.method-call",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#87a060"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression",
        "storage",
        "storage.modifier",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#c85552"
      }
    },
    {
      "name": "Types",
      "scope": [
        "storage.type",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution"
      ],
      "settings": {
        "foreground": "#8da101"
      }
    },
    {
      "name": "Constructors And Specials",
      "scope": [
        "meta.function-call.constructor",
        "support.class",
        "support.type.builtin",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#ef615e"
      }
    },
    {
      "name": "Tag Names",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "meta.tag.structure.any.html"
      ],
      "settings": {
        "foreground": "#8da101"
      }
    },
    {
      "name": "Tag Delimiters And Punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.separator.key-value",
        "punctuation.separator.delimiter",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#c85552"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.definition.generic"
      ],
      "settings": {
        "foreground": "#495157"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#5f9b93"
      }
    },
    {
      "name": "Markup Headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#87a060"
      }
    },
    {
      "name": "Markup Emphasis",
      "scope": [
        "markup.bold",
        "markup.italic"
      ],
      "settings": {
        "foreground": "#b67996"
      }
    },
    {
      "name": "Markup Links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#ef615e",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": [
        "markup.inserted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#5da111"
      }
    },
    {
      "name": "Diff Removed",
      "scope": [
        "markup.deleted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#c85552"
      }
    },
    {
      "name": "Diff Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#857F6E"
      }
    }
  ],
  "semanticTokenColors": {
    "comment": "#A39D8C",
    "string": "#d59600",
    "regexp": "#c85552",
    "number": "#b67996",
    "boolean": "#b67996",
    "keyword": "#c85552",
    "operator": "#495157",
    "namespace": "#5f9b93",
    "type": "#8da101",
    "typeParameter": "#8da101",
    "class": "#c85552",
    "interface": "#c85552",
    "enum": "#8da101",
    "enumMember": "#b67996",
    "struct": "#c85552",
    "function": "#87a060",
    "method": "#87a060",
    "decorator": "#87a060",
    "macro": "#5f9b93",
    "variable": "#495157",
    "parameter": "#5f9b93",
    "property": "#5f9b93",
    "label": "#8da101",
    "event": "#5f9b93",
    "modifier": "#5f9b93",
    "variable.defaultLibrary": "#b67996",
    "variable.readonly.defaultLibrary": "#b67996",
    "type.defaultLibrary": "#8da101"
  }
}

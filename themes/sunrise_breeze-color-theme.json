  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6e7681"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "meta.embedded.assembly"
      ],
      "settings": {
        "foreground": "#238636"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#2c9ab7"
      }
    },
    {
      "name": "Numbers And Booleans",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#e87c7c"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#e87c7c"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#1b1f23"
      }
    },
    {
      "name": "Builtin Variables And Parameters",
      "scope": [
        "variable.language",
        "variable.parameter",
        "variable.other.readwrite.alias",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#d64545"
      }
    },
    {
      "name": "Properties And Keys",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#d64545"
      }
    },
    {
      "name": "Functions And Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "meta.method-call",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#0969da"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression",
        "storage",
        "storage.modifier",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#8250df"
      }
    },
    {
      "name": "Types",
      "scope": [
        "storage.type",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution"
      ],
      "settings": {
        "foreground": "#bb8009"
      }
    },
    {
      "name": "Constructors And Specials",
      "scope": [
        "meta.function-call.constructor",
        "support.class",
        "support.type.builtin",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#2c9ab7"
      }
    },
    {
      "name": "Tag Names",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "meta.tag.structure.any.html"
      ],
      "settings": {
        "foreground": "#bb8009"
      }
    },
    {
      "name": "Tag Delimiters And Punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.separator.key-value",
        "punctuation.separator.delimiter",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#85e89d"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.definition.generic"
      ],
      "settings": {
        "foreground": "#1b1f23"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#d64545"
      }
    },
    {
      "name": "Markup Headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#0969da"
      }
    },
    {
      "name": "Markup Emphasis",
      "scope": [
        "markup.bold",
        "markup.italic"
      ],
      "settings": {
        "foreground": "#e87c7c"
      }
    },
    {
      "name": "Markup Links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#2c9ab7",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": [
        "markup.inserted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#238636"
      }
    },
    {
      "name": "Diff Removed",
      "scope": [
        "markup.deleted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#d64545"
      }
    },
    {
      "name": "Diff Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#5c6166"
      }
    }
  ],
  "semanticTokenColors": {
    "comment": "#6e7681",
    "string": "#238636",
    "regexp": "#85e89d",
    "number": "#e87c7c",
    "boolean": "#e87c7c",
    "keyword": "#8250df",
    "operator": "#1b1f23",

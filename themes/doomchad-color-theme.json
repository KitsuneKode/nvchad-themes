    "struct": "#48a6e6",
    "function": "#dc8ef3",
    "method": "#dc8ef3",
    "decorator": "#dc8ef3",
    "macro": "#ff6c6b",
    "variable": "#a7aebb",
    "parameter": "#ff6c6b",

    "enumMember": "#a87678",
    "struct": "#7e8e8e",
    "function": "#b3816a",
    "method": "#b3816a",
    "decorator": "#b3816a",
    "macro": "#8779a8",
    "variable": "#746862",
    "parameter": "#8779a8",
    "property": "#8779a8",
    "label": "#738199",
    "event": "#8779a8",
    "modifier": "#8779a8",
    "variable.defaultLibrary": "#a87678",

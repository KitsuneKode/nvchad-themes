    "class": "#8f3f71",
    "interface": "#8f3f71",
    "enum": "#b57614",
    "enumMember": "#af3a03",
    "struct": "#8f3f71",
    "function": "#076678",
    "method": "#076678",
    "decorator": "#076678",
    "macro": "#9d0006",
    "variable": "#504945",
    "parameter": "#9d0006",
    "property": "#9d0006",
    "label": "#b57614",
    "event": "#9d0006",

  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#164080"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "meta.embedded.assembly"
      ],
      "settings": {
        "foreground": "#01eca7"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#fd5e3a"
      }
    },
    {
      "name": "Numbers And Booleans",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#fd5e3a"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#fd5e3a"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#e8e5b5"
      }
    },
    {
      "name": "Builtin Variables And Parameters",
      "scope": [
        "variable.language",
        "variable.parameter",
        "variable.other.readwrite.alias",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#66def9"
      }
    },
    {
      "name": "Properties And Keys",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#66def9"
      }
    },
    {
      "name": "Functions And Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "meta.method-call",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#35b5ff"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression",
        "storage",
        "storage.modifier",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#66def9"
      }
    },
    {
      "name": "Types",
      "scope": [
        "storage.type",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution"
      ],
      "settings": {
        "foreground": "#fd5e3a"
      }
    },
    {
      "name": "Constructors And Specials",
      "scope": [
        "meta.function-call.constructor",
        "support.class",
        "support.type.builtin",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#fd5e3a"
      }
    },
    {
      "name": "Tag Names",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "meta.tag.structure.any.html"
      ],
      "settings": {
        "foreground": "#fd5e3a"
      }
    },
    {
      "name": "Tag Delimiters And Punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.separator.key-value",
        "punctuation.separator.delimiter",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#008DA3"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.definition.generic"
      ],
      "settings": {
        "foreground": "#e8e5b5"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#66def9"
      }
    },
    {
      "name": "Markup Headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#35b5ff"
      }
    },
    {
      "name": "Markup Emphasis",
      "scope": [
        "markup.bold",
        "markup.italic"
      ],
      "settings": {
        "foreground": "#fd5e3a"
      }
    },
    {
      "name": "Markup Links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#fd5e3a",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": [
        "markup.inserted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#01eca7"
      }
    },
    {
      "name": "Diff Removed",
      "scope": [
        "markup.deleted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#fc9487"
      }
    },
    {
      "name": "Diff Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#184686"
      }
    }
  ],
  "semanticTokenColors": {
    "comment": "#164080",
    "string": "#01eca7",
    "regexp": "#008DA3",
    "number": "#fd5e3a",
    "boolean": "#fd5e3a",
    "keyword": "#66def9",
    "operator": "#e8e5b5",
    "namespace": "#66def9",
    "type": "#fd5e3a",
    "typeParameter": "#fd5e3a",
    "class": "#66def9",
    "interface": "#66def9",
    "enum": "#fd5e3a",
    "enumMember": "#fd5e3a",
    "struct": "#66def9",
    "function": "#35b5ff",
    "method": "#35b5ff",
    "decorator": "#35b5ff",
    "macro": "#66def9",
    "variable": "#e8e5b5",
    "parameter": "#66def9",
    "property": "#66def9",
    "label": "#fd5e3a",
    "event": "#66def9",
    "modifier": "#66def9",
    "variable.defaultLibrary": "#fd5e3a",

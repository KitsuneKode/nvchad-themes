  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#3e4041"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "meta.embedded.assembly"
      ],
      "settings": {
        "foreground": "#82c29c"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#6791C9"
      }
    },
    {
      "name": "Numbers And Booleans",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#ecd28b"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ecd28b"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#edeff0"
      }
    },
    {
      "name": "Builtin Variables And Parameters",
      "scope": [
        "variable.language",
        "variable.parameter",
        "variable.other.readwrite.alias",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#f26e74"
      }
    },
    {
      "name": "Properties And Keys",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f26e74"
      }
    },
    {
      "name": "Functions And Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "meta.method-call",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#709ad2"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression",
        "storage",
        "storage.modifier",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#c58cec"
      }
    },
    {
      "name": "Types",
      "scope": [
        "storage.type",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution"
      ],
      "settings": {
        "foreground": "#e79881"
      }
    },
    {
      "name": "Constructors And Specials",
      "scope": [
        "meta.function-call.constructor",
        "support.class",
        "support.type.builtin",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#6791C9"
      }
    },
    {
      "name": "Tag Names",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "meta.tag.structure.any.html"
      ],
      "settings": {
        "foreground": "#e79881"
      }
    },
    {
      "name": "Tag Delimiters And Punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.separator.key-value",
        "punctuation.separator.delimiter",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#e8646a"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.definition.generic"
      ],
      "settings": {
        "foreground": "#edeff0"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#f26e74"
      }
    },
    {
      "name": "Markup Headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#709ad2"
      }
    },
    {
      "name": "Markup Emphasis",
      "scope": [
        "markup.bold",
        "markup.italic"
      ],
      "settings": {
        "foreground": "#ecd28b"
      }
    },
    {
      "name": "Markup Links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#6791C9",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": [
        "markup.inserted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#78B892"
      }
    },
    {
      "name": "Diff Removed",
      "scope": [
        "markup.deleted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#DF5B61"
      }
    },
    {
      "name": "Diff Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#505253"
      }
    }
  ],
  "semanticTokenColors": {
    "comment": "#3e4041",
    "string": "#82c29c",
    "regexp": "#e8646a",
    "number": "#ecd28b",
    "boolean": "#ecd28b",
    "keyword": "#c58cec",
    "operator": "#edeff0",
    "namespace": "#f26e74",
    "type": "#e79881",
    "typeParameter": "#e79881",
    "class": "#c58cec",
    "interface": "#c58cec",
    "enum": "#e79881",
    "enumMember": "#ecd28b",
    "struct": "#c58cec",
    "function": "#709ad2",
    "method": "#709ad2",
    "decorator": "#709ad2",
    "macro": "#f26e74",
    "variable": "#edeff0",
    "parameter": "#f26e74",
    "property": "#f26e74",
    "label": "#e79881",
    "event": "#f26e74",

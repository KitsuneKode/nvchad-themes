    "red": "#fb6f6f",
    "babyPink": "#ffa3a0",
    "pink": "#ffb3a8",
    "line": "#21262d",
    "green": "#56d364",
    "vibrantGreen": "#57d27d",
    "nordBlue": "#58a6ff",
    "blue": "#58a6ff",
    "yellow": "#ffdf5d",
    "sun": "#f0b000",
    "purple": "#bc8cff",

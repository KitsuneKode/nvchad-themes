      "@constructor": {
        "fg": "#89ddff"
      },
      "@delimiter": {
        "fg": "#DA70CA"
      },
      "@keyword.exception": {
        "fg": "#c792ea"
      },
      "@variable.member": {
        "fg": "#eeffff"
      },
      "@function": {
        "fg": "#82aaff"
      },
      "@function.macro": {
        "fg": "#6e98eb"
      },
      "@keyword": {
        "fg": "#89ddff"
      },
      "@module": {
        "fg": "#ffcb6b"
      },
      "@operator": {
        "fg": "#89ddff"
      },
      "@punctuation.bracket": {
        "fg": "#DA70CA"
      },
      "@punctuation.delimiter": {
        "fg": "#DA70CA"
      },
      "@keyword.repeat": {
        "fg": "#c792ea"
      },
      "@string": {
        "fg": "#c3e88d"
      },
      "@type.qualifier": {
        "fg": "#89ddff"
      }
    },
    "syntax": {
      "Identifier": {
        "fg": "#eeffff"
      },
      "Include": {
        "fg": "#c792ea"

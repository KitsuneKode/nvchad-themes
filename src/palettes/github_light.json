{
  "id": "github_light",
  "displayName": "NvChad Github Light",
  "author": "NvChad",
  "type": "light",
  "base30": {
    "white": "#24292e",
    "darkerBlack": "#f3f5f7",
    "black": "#ffffff",
    "black2": "#edeff1",
    "oneBg": "#eaecee",
    "oneBg2": "#e1e3e5",
    "oneBg3": "#d7d9db",
    "grey": "#c7c9cb",
    "greyFg": "#bcbec0",
    "greyFg2": "#b1b3b5",
    "lightGrey": "#a6a8aa",
    "red": "#DE2C2E",
    "babyPink": "#ea4aaa",
    "pink": "#b93a86",
    "line": "#eaecee",
    "green": "#18654B",
    "vibrantGreen": "#28a745",
    "nordBlue": "#0366d6",
    "blue": "#0D7FDD",
    "yellow": "#dbab09",
    "sun": "#f9c513",
    "purple": "#8263EB",
    "darkPurple": "#5a32a3",
    "teal": "#22839b",
    "orange": "#d15704",
    "cyan": "#0598bc",
    "statuslineBg": "#edeff1",
    "lightBg": "#e1e3e5",
    "pmenuBg": "#8263EB",
    "folderBg": "#6a737d"
  },
  "base16": {
    "base00": "#ffffff",
    "base01": "#edeff1",
    "base02": "#e1e3e5",
    "base03": "#d7d9db",
    "base04": "#c7c9cb",
    "base05": "#383d42",
    "base06": "#2e3338",
    "base07": "#24292e",
    "base08": "#5a32a3",
    "base09": "#b93a86",
    "base0A": "#b08800",
    "base0B": "#4c2889",
    "base0C": "#8263EB",
    "base0D": "#005cc5",
    "base0E": "#DE2C2E",
    "base0F": "#044289"
  },
  "polishHl": {
    "treesitter": {
      "@punctuation.bracket": {
        "fg": "#0D7FDD"
      },
      "@variable.member.key": {
        "fg": "#24292e"
      },
      "@constructor": {
        "fg": "#28a745"
      },
      "@operator": {
        "fg": "#d15704"
      }
    },
    "syntax": {
      "Constant": {
        "fg": "#24292e"
      },
      "Tag": {
        "fg": "#28a745"
      }
    }
  }
}

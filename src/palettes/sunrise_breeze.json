        "fg": "#0969da"
      },
      "@variable.member": {
        "fg": "#1b1f23"
      },
      "@constant": {
        "fg": "#bb8009"
      },
      "@constant.builtin": {
        "fg": "#bb8009"
      },
      "@constant.macro": {
        "fg": "#bb8009"
      },
      "@function": {
        "fg": "#0969da"
      },
      "@function.builtin": {
        "fg": "#0969da"
      },
      "@function.call": {
        "fg": "#0969da"
      },
      "@function.macro": {
        "fg": "#d64545"
      },
      "@function.method": {
        "fg": "#0969da"
      },
      "@function.method.call": {
        "fg": "#0969da"
      },
      "@constructor": {
        "fg": "#8250df"
      },
      "@type": {
        "fg": "#2c9ab7"
      },
      "@type.builtin": {
        "fg": "#2c9ab7"
      },
      "@type.definition": {
        "fg": "#2c9ab7"
      },

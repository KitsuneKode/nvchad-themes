      },
      "@comment.note": {
        "fg": "#8250df"
      },
      "@markup.heading": {
        "fg": "#0969da",
        "bold": true
      },
      "@markup.bold": {
        "fg": "#1b1f23",
        "bold": true
      },
      "@markup.italic": {
        "fg": "#1b1f23",
        "italic": true
      },
      "@markup.link": {
        "fg": "#0969da"
      },
      "@markup.list": {
        "fg": "#1b1f23"
      }

        "fg": "#d64545"
      },
      "@keyword.operator": {
        "fg": "#d64545"
      },
      "@keyword.conditional": {
        "fg": "#d64545"
      },
      "@keyword.return": {
        "fg": "#d64545"
      },
      "@property": {
        "fg": "#1b1f23"
      },
      "@attribute": {
        "fg": "#8250df"
      },
      "@string": {
        "fg": "#238636"
      },
      "@string.documentation": {
        "fg": "#6e7681",
        "italic": true
      },
      "@string.escape": {
        "fg": "#d9822b"
      },
      "@string.special": {
        "fg": "#bb8009"
      },
      "@boolean": {
